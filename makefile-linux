# C++ specific stuff
CXX = g++
CFLAGS = 
OUTPUT =

# Includes
LIBS = -I"./include/glm-0.9.9.8/glm/" -I"./include/glfw-3.3.7/include/" -I"./include/vulkansdk-linux-x86_64-1.3.216.0/1.3.216.0/x86_64/include/" -I"/usr/include/" -m64 -lglfw -lGL -lvulkan
GLSLC = "./include/vulkansdk-linux-x86_64-1.3.216.0/1.3.216.0/x86_64/bin/glslc"

# Directories
OBJ_DIR = ./build/obj
SRC_DIR = ./src

OBJECTS = $(patsubst %.cpp, %.o, $(SOURCES))
EXPECTED_OBJECTS =  $(patsubst %.o, $(OBJ_DIR)/%.o, $(notdir $(OBJECTS)))

#######################################################
### Do not modify anything above this block of text ###
#######################################################
SOURCES = $(SRC_DIR)/main.cpp $(wildcard $(RENDER_DIR)/*.cpp) $(wildcard $(WORLD_DIR)/*.cpp) $(wildcard $(GAME_DIR)/*.cpp)

# Code directories
RENDER_DIR = ./src/render
WORLD_DIR = ./src/world
GAME_DIR = = ./src/game

debug: CFLAGS += -g
debug: OUTPUT = -o ./build/output_debug
debug: all

build: OUTPUT = -o ./build/output
build: all

all: $(OBJECTS)
	$(CXX) $(CFLAGS) $(OUTPUT) $(EXPECTED_OBJECTS) $(LIBS)

$(OBJECTS): src/%.o : src/%.cpp
	$(CXX) $(CFLAGS) -c $< $(LIBS) -o $(OBJ_DIR)/$(@F)

shaders: .PHONY
.PHONY: /shaders/simple_shader.vert ./shaders/simple_shader.frag
	$(GLSLC) ./shaders/simple_shader.vert -o ./shaders/simple_shader.vert.spv
	$(GLSLC) ./shaders/simple_shader.frag -o ./shaders/simple_shader.frag.spv

clean:
	rm -f ./build/obj/*
	rm -f ./build/output
	rm -f ./build/output_debug
